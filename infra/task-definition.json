{
  "family": "elimu-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::093583252030:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::093583252030:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "elimu-api",
      "image": "093583252030.dkr.ecr.eu-west-1.amazonaws.com/elimu-api:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 5000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "5000" }
      ],
      "secrets": [
        {
          "name": "SUPABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:093583252030:secret:elimu/SUPABASE_URL"
        },
        {
          "name": "SUPABASE_SERVICE_ROLE_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:093583252030:secret:elimu/SUPABASE_SERVICE_ROLE_KEY"
        },
        {
          "name": "ISSUER_URL",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:093583252030:secret:elimu/ISSUER_URL"
        },
        {
          "name": "OIDC_CLIENT_ID",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:093583252030:secret:elimu/OIDC_CLIENT_ID"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/elimu-api",
          "awslogs-region": "eu-west-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:5000/api/healthz || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
