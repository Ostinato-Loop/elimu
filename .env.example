# RALD ELIMU — Environment Variables
# Copy to .env and fill in values

# ── Server ─────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ───────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/elimu

# ── RALD Auth (OIDC) ────────────────────────────────────────────────────────
# RALD Identity OIDC issuer URL
ISSUER_URL=https://auth.rald.cloud/oidc
# Client ID registered with RALD Auth
REPL_ID=your-client-id-here

# ── RALD Mail ──────────────────────────────────────────────────────────────
# RALD Mail API base URL (for provisioning school email infrastructure)
RALD_MAIL_API_URL=https://mail.rald.cloud/api
RALD_MAIL_API_KEY=

# ── SEKANI AI ──────────────────────────────────────────────────────────────
SEKANI_API_URL=https://ai.rald.cloud/api
SEKANI_API_KEY=

# ── RALD ALIA (Payments) ───────────────────────────────────────────────────
ALIA_API_URL=https://alia.rald.cloud/api
ALIA_API_KEY=

# ── RALD Voice ─────────────────────────────────────────────────────────────
RALD_VOICE_API_URL=https://voice.rald.cloud/api
RALD_VOICE_API_KEY=

# ── RALD Analytics ─────────────────────────────────────────────────────────
RALD_ANALYTICS_API_URL=https://analytics.rald.cloud/api
RALD_ANALYTICS_API_KEY=
